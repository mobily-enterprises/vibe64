{
  "name": "vibe64",
  "version": "0.1.22",
  "private": false,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "description": "Run Vibe64 against the current project.",
  "bin": {
    "vibe64": "bin/run.js"
  },
  "files": [
    ".jskit/lock.json",
    "bin/",
    "config/",
    "dist/",
    "packages/",
    "server.js",
    "server/",
    "tooling/"
  ],
  "bundleDependencies": [
    "@local/adapter-setup-doctor",
    "@local/vibe64-accounts",
    "@local/vibe64-adapters",
    "@local/vibe64-artifacts",
    "@local/vibe64-core",
    "@local/vibe64-project",
    "@local/vibe64-runtime",
    "@local/vibe64-sessions",
    "@local/vibe64-terminals",
    "@local/current-app",
    "@local/main",
    "@local/project-setup-doctor",
    "@local/setup-doctor-core",
    "@local/studio-setup-doctor",
    "@local/studio-terminal-core"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prepack": "npm run verify:packages && npm run build",
    "server": "node ./bin/server.js --no-open",
    "server:all": "node ./bin/server.js --no-open",
    "server:app": "SERVER_SURFACE=app node ./bin/server.js --no-open",
    "start": "node ./bin/server.js --no-open",
    "dev": "node ./bin/dev.js",
    "dev:all": "node ./bin/dev.js",
    "dev:app": "VITE_SURFACE=app node ./bin/dev.js",
    "build": "vite build",
    "build:all": "vite build",
    "build:app": "VITE_SURFACE=app vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs/site",
    "docs:build": "vitepress build docs/site",
    "docs:preview": "vitepress preview docs/site",
    "lint": "eslint .",
    "test": "node --test tests/server/*.test.js",
    "test:client": "vitest run tests/client",
    "test:e2e": "playwright test --config playwright.config.ts tests/e2e/self-contained-smoke.spec.ts tests/e2e/dumb-client-autopilot.spec.ts",
    "test:e2e:shell": "playwright test --config playwright.config.ts tests/e2e/base-shell.spec.ts",
    "test:e2e:live": "npm run build && VIBE64_LIVE_E2E=1 playwright test --config playwright.config.ts tests/e2e/live-vibe64-workflow.spec.ts",
    "verify": "npx jskit app verify && npm run verify:packages && npm run --if-present verify:app",
    "verify:packages": "node ./tooling/verify-package-boundaries.mjs",
    "host:pull-toolchain-images": "node ./bin/pull-toolchain-images.js",
    "smoke:package": "node ./tooling/package-install-smoke.mjs",
    "release": "node ./scripts/npm-release.js",
    "jskit:release": "npx jskit app release",
    "jskit:update": "npx jskit app update-packages"
  },
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.2.0",
    "@jskit-ai/http-runtime": "0.1.82",
    "@jskit-ai/kernel": "0.x",
    "@jskit-ai/shell-web": "0.1.82",
    "@jskit-ai/users-web": "0.1.98",
    "@local/adapter-setup-doctor": "0.1.0",
    "@local/vibe64-accounts": "0.1.0",
    "@local/vibe64-artifacts": "0.1.0",
    "@local/vibe64-core": "0.1.0",
    "@local/vibe64-project": "0.1.0",
    "@local/vibe64-sessions": "0.1.0",
    "@local/vibe64-terminals": "0.1.0",
    "@local/current-app": "0.1.0",
    "@local/main": "0.1.0",
    "@local/project-setup-doctor": "0.1.0",
    "@local/studio-setup-doctor": "0.1.0",
    "@mdi/js": "^7.4.47",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/vue-query": "^5.90.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.56",
    "execa": "^9.6.1",
    "fastify": "^5.7.4",
    "get-port": "^7.2.0",
    "json-rest-schema": "^1.0.16",
    "node-pty": "^1.1.0",
    "open": "^11.0.0",
    "pinia": "^3.0.4",
    "strip-ansi": "^7.2.0",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.0",
    "ws": "^8.20.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "redis": "^5.8.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "@jskit-ai/realtime": "0.x",
    "@local/vibe64-adapters": "0.1.0",
    "@local/vibe64-runtime": "0.1.0",
    "@local/studio-terminal-core": "0.1.0",
    "@local/setup-doctor-core": "0.1.0"
  },
  "devDependencies": {
    "@jskit-ai/agent-docs": "0.1.44",
    "@jskit-ai/config-eslint": "0.1.82",
    "@jskit-ai/jskit-cli": "0.2.92",
    "@playwright/test": "^1.57.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.39.1",
    "vite": "^6.1.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  }
}
