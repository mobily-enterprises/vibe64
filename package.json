{
  "name": "@vibe-armor/run",
  "version": "0.1.8",
  "private": false,
  "type": "module",
  "description": "Run AI Studio against the current project.",
  "bin": {
    "ai-studio": "bin/server.js"
  },
  "files": [
    ".jskit/lock.json",
    "bin/",
    "config/",
    "dist/",
    "packages/",
    "server.js",
    "server/",
    "tooling/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prepack": "npm run build",
    "server": "node ./bin/server.js",
    "server:all": "node ./bin/server.js",
    "server:home": "SERVER_SURFACE=home node ./bin/server.js",
    "start": "node ./bin/server.js",
    "dev": "node ./bin/dev.js",
    "dev:all": "node ./bin/dev.js",
    "dev:home": "VITE_SURFACE=home node ./bin/dev.js",
    "build": "vite build",
    "build:all": "vite build",
    "build:home": "VITE_SURFACE=home vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs/site",
    "docs:build": "vitepress build docs/site",
    "docs:preview": "vitepress preview docs/site",
    "lint": "eslint .",
    "test": "node --test tests/server/*.test.js",
    "test:client": "vitest run tests/client",
    "test:e2e": "playwright test --config playwright.config.ts tests/e2e/self-contained-smoke.spec.ts",
    "test:e2e:legacy": "playwright test --config playwright.config.ts tests/e2e/base-shell.spec.ts",
    "test:e2e:live": "npm run build && AI_STUDIO_LIVE_E2E=1 playwright test --config playwright.config.ts tests/e2e/live-ai-studio-workflow.spec.ts",
    "verify": "jskit app verify && npm run --if-present verify:app",
    "release": "jskit app release",
    "jskit:update": "jskit app update-packages"
  },
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.2.0",
    "@jskit-ai/http-runtime": "0.1.82",
    "@jskit-ai/kernel": "0.1.83",
    "@jskit-ai/shell-web": "0.1.82",
    "@jskit-ai/users-web": "0.1.98",
    "@local/adapter-setup-doctor": "file:packages/adapter-setup-doctor",
    "@local/ai-studio-accounts": "file:packages/ai-studio-accounts",
    "@local/ai-studio-artifacts": "file:packages/ai-studio-artifacts",
    "@local/ai-studio-project": "file:packages/ai-studio-project",
    "@local/ai-studio-sessions": "file:packages/ai-studio-sessions",
    "@local/ai-studio-terminals": "file:packages/ai-studio-terminals",
    "@local/current-app": "file:packages/current-app",
    "@local/main": "file:packages/main",
    "@local/project-setup-doctor": "file:packages/project-setup-doctor",
    "@local/studio-setup-doctor": "file:packages/studio-setup-doctor",
    "@mdi/js": "^7.4.47",
    "@tanstack/vue-query": "^5.90.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.56",
    "execa": "^9.6.1",
    "fastify": "^5.7.4",
    "get-port": "^7.2.0",
    "json-rest-schema": "1.x.x",
    "node-pty": "^1.1.0",
    "open": "^11.0.0",
    "pinia": "^3.0.4",
    "strip-ansi": "^7.2.0",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.0"
  },
  "devDependencies": {
    "@jskit-ai/agent-docs": "0.1.44",
    "@jskit-ai/config-eslint": "0.1.82",
    "@jskit-ai/jskit-cli": "0.2.92",
    "@playwright/test": "^1.57.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.39.1",
    "vite": "^6.1.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18"
  }
}
